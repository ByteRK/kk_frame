<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="@color/keyboard_color_key_sp_bg_pressed"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>
            <item android:gravity="center" android:drawable="@mipmap/keyboard_backspace"/>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape>
                    <solid android:color="@color/keyboard_color_key_sp_bg"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>
            <item android:gravity="center" android:drawable="@mipmap/keyboard_backspace"/>
        </layer-list>
    </item>
</selector>