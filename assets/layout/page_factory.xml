<?xml version="1.0" encoding="utf-8"?>
<ViewFlipper xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_demo">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <GridLayout
            android:id="@+id/factory_menu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="8"
            android:padding="10dp">
            <Button
                android:id="@+id/to_info"
                style="@style/factory_menu_btn"
                android:text="项目信息"/>
            <Button
                android:id="@+id/to_network"
                style="@style/factory_menu_btn"
                android:text="网络信息"/>
            <Button
                android:id="@+id/to_switch"
                style="@style/factory_menu_btn"
                android:text="功能开关"/>
            <Button
                android:id="@+id/to_touch"
                style="@style/factory_menu_btn"
                android:text="触摸测试"/>
            <Button
                android:id="@+id/to_color"
                style="@style/factory_menu_btn"
                android:text="显示测试"/>
            <Button
                android:id="@+id/to_wifi"
                style="@style/factory_menu_btn"
                android:text="WIFI检测"/>
            <Button
                android:id="@+id/to_aging"
                style="@style/factory_menu_btn"
                android:text="屏幕老化"/>
            <Button
                android:id="@+id/exit"
                style="@style/factory_menu_btn"
                android:text="结束测试"/>
        </GridLayout>

        <TextView
            android:id="@+id/copyright"
            style="@style/font_medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:text="Power By Cdroid [https://gitee.com/houstudio/Cdroid]"/>
    </RelativeLayout>

    <!-- 网络信息 -->
    <include layout="@layout/page_factory_info"
        android:id="@+id/info_test"/>

    <!-- 项目信息 -->
    <include layout="@layout/page_factory_network"
        android:id="@+id/network_test"/>

    <!-- 功能开关 -->
    <include layout="@layout/page_factory_switch"
        android:id="@+id/switch_test"/>

    <!-- 触摸测试 -->
    <include layout="@layout/page_factory_touch"
        android:id="@+id/touch_test"/>

    <!-- 显示测试 -->
    <include layout="@layout/page_factory_color"
        android:id="@+id/color_test"/>

    <!-- WIFI检测 -->
    <include layout="@layout/page_factory_wifi"
        android:id="@+id/wifi_test"/>

    <!-- 屏幕老化 -->
    <include layout="@layout/page_factory_color"
        android:id="@+id/aging_test"/>

</ViewFlipper>