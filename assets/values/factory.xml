<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="factory_text">#FFFFFF</color>

    <color name="factory_btn_default">#70a1ff</color>
    <color name="factory_btn_pressed">#4aa0d5</color>
    <color name="factory_btn_activated">#10ac84</color>
    <color name="factory_btn_activated_pressed">#1dd1a1</color>
    <color name="factory_btn_disable">#feca57</color>

    <style name="factory_menu_btn">
        <item name="android:layout_width">115dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/factory_menu_btn</item>
        <item name="android:textColor">@color/factory_text</item>
        <item name="android:textSize">20sp</item>
        <item name="android:gravity">center</item>
        <item name="android:stateListAnimator">@animator/btn_click_scale</item>
    </style>

    <style name="factory_exit_btn">
        <item name="android:layout_width">160dp</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:layout_alignParentBottom">true</item>
        <item name="android:layout_alignParentEnd">true</item>
        <item name="android:layout_margin">20dp</item>
        <item name="android:background">@drawable/factory_menu_btn</item>
        <item name="android:textColor">@color/factory_text</item>
        <item name="android:textSize">25sp</item>
        <item name="android:gravity">center</item>
        <item name="android:stateListAnimator">@animator/btn_click_scale</item>
    </style>
    <style name="factory_refresh_btn">
        <item name="android:layout_width">160dp</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:layout_above">@id/exit</item>
        <item name="android:layout_alignEnd">@id/exit</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:background">@drawable/factory_menu_btn</item>
        <item name="android:textColor">@color/factory_text</item>
        <item name="android:textSize">25sp</item>
        <item name="android:text">刷新</item>
        <item name="android:gravity">center</item>
        <item name="android:stateListAnimator">@animator/btn_click_scale</item>
    </style>
</resources>