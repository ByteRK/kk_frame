<resources>
    <!--    大背景-->
    <color name="keyboard_color_bg">#000000</color>
    <!--    容器背景-->
    <color name="keyboard_color_box_bg">#d6e6f2</color>
    <!--    输入框-->
    <color name="keyboard_color_input">#f9f9f9</color>
    <color name="keyboard_color_description">#88f9f9f9</color>
    <color name="keyboard_color_input_bg">#57606f</color>
    <color name="keyboard_color_input_bg_stroke">#d6e6f2</color>
    <!--    功能键-->
    <color name="keyboard_color_func">#FFFFFF</color>
    <color name="keyboard_color_func_bg">#5e87b8</color>
    <color name="keyboard_color_func_bg_pressed">#83cee0</color>
    <!--    KEY-->
    <color name="keyboard_color_key">#FFFFFF</color>
    <color name="keyboard_color_key_bg">#718093</color>
    <color name="keyboard_color_key_bg_pressed">#7f8fa6</color>
    <!--    特殊KEY-->
    <color name="keyboard_color_key_sp">#FFFFFF</color>
    <color name="keyboard_color_key_sp_bg">#2f3640</color>
    <color name="keyboard_color_key_sp_bg_pressed">#353b48</color>


    <!--    输入框-->
    <style name="keyboard_input_box">
        <item name="android:layout_width">560dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textColor">@color/keyboard_color_input</item>
        <item name="android:textSize">34sp</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:background">@drawable/keyboard_input</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:cursorVisible">true</item>
    </style>
    <!--    功能键-->
    <style name="keyboard_cancel">
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_alignTop">@id/input_box</item>
        <item name="android:layout_toEndOf">@id/input_box</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/keyboard_color_func</item>
        <item name="android:textSize">34sp</item>
        <item name="android:background">@drawable/keyboard_func</item>
    </style>
    <style name="keyboard_enter">
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_alignTop">@id/input_box</item>
        <item name="android:layout_toEndOf">@id/cancel</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/keyboard_color_func</item>
        <item name="android:textSize">34sp</item>
        <item name="android:background">@drawable/keyboard_func</item>
    </style>
    <!--    容器-->
    <style name="keyboard_box">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:background">@drawable/keyboard_box</item>
        <item name="android:orientation">vertical</item>
        <item name="android:showDividers">middle</item>
        <item name="android:divider">@drawable/keyboard_space_v</item>
        <item name="android:padding">6dp</item>
    </style>
    <!--    容器 行-->
    <style name="keyboard_box_line">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:showDividers">middle</item>
        <item name="android:divider">@drawable/keyboard_space_h</item>
    </style>
    <!--    KEY-->
    <style name="keyboard_key">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/keyboard_color_key</item>
        <item name="android:background">@drawable/keyboard_key</item>
        <item name="android:text">key</item>
    </style>
    <!--    特殊KEY-->
    <style name="keyboard_key_sp">
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/keyboard_color_key_sp</item>
        <item name="android:background">@drawable/keyboard_key_sp</item>
        <item name="android:text">spk</item>
    </style>
    <!--    空格键-->
    <style name="keyboard_key_space">
        <item name="android:layout_width">380dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/keyboard_color_key</item>
        <item name="android:background">@drawable/keyboard_key</item>
        <item name="android:text">spk</item>
    </style>
    <!--    回退键-->
    <style name="keyboard_key_backspace">
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/keyboard_color_key_sp</item>
        <item name="android:background">@drawable/keyboard_backspace</item>
        <item name="android:text"> </item>
    </style>
    <!--    大写键-->
    <style name="keyboard_key_shift">
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/keyboard_color_key_sp</item>
        <item name="android:background">@drawable/keyboard_shift</item>
        <item name="android:text"> </item>
    </style>
</resources>
