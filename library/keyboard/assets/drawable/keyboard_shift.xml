<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <selector>
            <item android:state_selected="true">
                <shape>
                    <solid android:color="@color/keyboard_color_key_sp_bg_pressed"/>
                    <stroke android:width="4dp" android:color="@color/keyboard_color_key_bg"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>
            <item android:state_pressed="true">
                <shape>
                    <solid android:color="@color/keyboard_color_key_sp_bg_pressed"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>
            <item>
                <shape>
                    <solid android:color="@color/keyboard_color_key_sp_bg"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>
        </selector>
    </item>
    <item android:gravity="center">
        <selector>
            <item android:state_selected="true" android:drawable="@mipmap/keyboard_shift_2"/>
            <item android:state_activated="true" android:drawable="@mipmap/keyboard_shift_1"/>
            <item android:drawable="@mipmap/keyboard_shift"/>
        </selector>
    </item>
</layer-list>